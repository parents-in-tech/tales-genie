{
  "name": "tales-genie",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered illustrated bedtime stories for kids, in six languages. Built by Parents in Tech, runs free on Cloudflare Workers AI.",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && tsc --noEmit && astro build",
    "preview": "astro preview",
    "start": "astro dev",
    "lint": "eslint . --ext .js,.ts,.astro",
    "format": "prettier --write .",
    "type-check": "astro check && tsc --noEmit",
    "clean": "rm -rf dist .astro .vercel"
  },
  "dependencies": {
    "@ai-sdk/google": "^4.0.14",
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^14.1.3",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/nunito": "^5.2.7",
    "ai": "^7.0.26",
    "astro": "^7.0.9",
    "tailwindcss": "^3.4.19",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "autoprefixer": "^10.5.2",
    "eslint": "^8.57.1",
    "eslint-plugin-astro": "^0.31.4",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.13.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.110.0"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/parents-in-tech/tales-genie.git"
  },
  "keywords": [
    "astro",
    "story-generator",
    "ai",
    "cloudflare-workers-ai",
    "kids",
    "bedtime-stories"
  ],
  "author": {
    "name": "Parents in Tech",
    "url": "https://parentsintech.org"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/parents-in-tech/tales-genie/issues"
  },
  "homepage": "https://talesgenie.parentsintech.org",
  "packageManager": "pnpm@11.8.0"
}
