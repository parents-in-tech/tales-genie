{
  "name": "astro-story-generator",
  "version": "0.1.0",
  "private": true,
  "description": "An AI-powered story generator built with Astro and Google's Gemini API. This application creates engaging stories with inline images generated along the plot line.",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && tsc --noEmit && astro build",
    "preview": "astro preview",
    "start": "astro dev",
    "lint": "eslint . --ext .js,.ts,.astro",
    "format": "prettier --write .",
    "type-check": "astro check && tsc --noEmit",
    "clean": "rm -rf dist .astro .vercel"
  },
  "dependencies": {
    "@ai-sdk/google": "^1.2.1",
    "@astrojs/tailwind": "^6.0.1",
    "@astrojs/vercel": "^8.1.3",
    "@google/generative-ai": "^0.2.1",
    "ai": "^4.2.0",
    "astro": "^5.5.4",
    "tailwindcss": "^3.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.25",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-astro": "^0.31.4",
    "prettier": "^3.2.5",
    "prettier-plugin-astro": "^0.13.0",
    "typescript": "^5.4.2"
  },
  "engines": {
    "node": ">=18.14.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openrijal/astro-story-generator.git"
  },
  "keywords": [
    "astro",
    "story-generator",
    "ai",
    "gemini",
    "google-ai"
  ],
  "author": {
    "name": "Open Rijal",
    "url": "https://github.com/openrijal"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/openrijal/astro-story-generator/issues"
  },
  "homepage": "https://github.com/openrijal/astro-story-generator#readme"
}
