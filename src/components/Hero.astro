---
import { getTranslator } from '../utils/i18n';

const lang = Astro.cookies.get('language')?.value || 'en';
const t = getTranslator(lang);
---

<header class="relative text-center pt-14 pb-8 overflow-hidden">
  <!-- Twinkling stars -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <span class="star left-[12%] top-[22%]" style="animation-delay:0s"></span>
    <span class="star left-[22%] top-[58%]" style="animation-delay:0.9s"></span>
    <span class="star left-[38%] top-[12%]" style="animation-delay:1.6s"></span>
    <span class="star right-[35%] top-[18%]" style="animation-delay:0.4s"></span>
    <span class="star right-[18%] top-[48%]" style="animation-delay:1.2s"></span>
    <span class="star right-[9%] top-[16%]" style="animation-delay:2s"></span>
  </div>

  <!-- Open book + moon illustration -->
  <div class="mx-auto w-28 h-28 mb-5 animate-floaty" aria-hidden="true">
    <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full drop-shadow-lg">
      <!-- moon -->
      <circle cx="82" cy="30" r="16" class="fill-gold" opacity="0.9"/>
      <circle cx="76" cy="26" r="14" class="fill-paper"/>
      <!-- sparkles -->
      <path d="M30 18l1.8 4.6L36.5 24l-4.7 1.4L30 30l-1.8-4.6L23.5 24l4.7-1.4z" class="fill-ember" opacity="0.85"/>
      <path d="M100 58l1.2 3.1 3.2.9-3.2 1-1.2 3-1.2-3-3.2-1 3.2-.9z" class="fill-gold"/>
      <!-- open book -->
      <path d="M60 96c-9-7-22-9-38-7V44c16-2 29 0 38 7 9-7 22-9 38-7v45c-16-2-29 0-38 7z" class="fill-card stroke-ink" stroke-width="3.5" stroke-linejoin="round"/>
      <path d="M60 51v45" class="stroke-ink" stroke-width="3.5" stroke-linecap="round"/>
      <!-- text lines -->
      <path d="M31 56c7-.7 13-.3 19 1.5M31 66c7-.7 13-.3 19 1.5M31 76c7-.7 13-.3 19 1.5" class="stroke-ink-soft" stroke-width="2.6" stroke-linecap="round" opacity="0.75"/>
      <path d="M70 57.5c6-1.8 12-2.2 19-1.5M70 67.5c6-1.8 12-2.2 19-1.5M70 77.5c6-1.8 12-2.2 19-1.5" class="stroke-ink-soft" stroke-width="2.6" stroke-linecap="round" opacity="0.75"/>
    </svg>
  </div>

  <h1 class="font-display font-bold text-5xl sm:text-6xl tracking-tight mb-4">
    {t('talesGenie')}
  </h1>
  <p class="text-lg sm:text-xl text-ink-soft max-w-xl mx-auto text-balance">
    {t('createStories')}
  </p>
</header>

<style>
  .star {
    position: absolute;
    width: 6px;
    height: 6px;
    background: rgb(var(--c-gold));
    clip-path: polygon(50% 0%, 62% 38%, 100% 50%, 62% 62%, 50% 100%, 38% 62%, 0% 50%, 38% 38%);
    animation: twinkle 2.6s infinite ease-in-out;
  }
  .text-balance { text-wrap: balance; }
</style>
