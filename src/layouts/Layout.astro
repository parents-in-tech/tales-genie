---
import { getTranslator } from '../utils/i18n';

interface Props {
  title: string;
}

const { title } = Astro.props;
const lang = Astro.cookies.get('language')?.value || 'en';
const t = getTranslator(lang);
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="AI-powered story generator with inline images">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script>
      const lang = localStorage.getItem('language') || 'en';
      document.cookie = `language=${lang};path=/`;
    </script>
  </head>
  <body class="bg-background text-text min-h-screen flex flex-col">
    <header class="bg-surface shadow-md z-10">
      <nav class="w-full px-6 py-4 flex justify-between items-center">
        <a href="/" class="text-2xl font-bold text-primary">{t('talesGenie')}</a>
      </nav>
    </header>
    <main class="flex-1 w-full py-8">
      <slot />
    </main>
    <footer class="bg-surface border-t">
      <div class="w-full px-6 py-4 text-center text-gray-500">
        © {new Date().getFullYear()} {t('talesGenie')}. {t('allRightsReserved')}
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --accent: 136, 58, 234;
    --accent-light: 224, 204, 250;
    --accent-dark: 49, 10, 101;
    --accent-gradient: linear-gradient(45deg, rgb(var(--accent)), rgb(var(--accent-light)) 30%, white 60%);
  }
</style>