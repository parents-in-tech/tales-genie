
---
import { getTranslator } from '../utils/i18n';

interface Props {
  title: string;
}

const { title } = Astro.props;
const lang = Astro.cookies.get('language')?.value || 'en';
const t = getTranslator(lang);
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="AI-powered story generator with inline images">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script>
      const lang = localStorage.getItem('language') || 'en';
      document.cookie = `language=${lang};path=/`;
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-gradient-to-br from-background to-surface">
    
    <main class="flex-1 w-full py-8">
      <slot />
    </main>
    
  </body>
</html>

<style is:global>
  :root {
    --accent: 213, 252, 81;
    --accent-light: 224, 255, 128;
    --accent-dark: 176, 217, 48;
    --accent-gradient: linear-gradient(45deg, rgb(var(--accent)), rgb(var(--accent-light)) 30%, #D9D9D9 60%);
  }
</style>
